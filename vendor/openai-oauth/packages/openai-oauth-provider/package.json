{
	"name": "openai-oauth-provider",
	"version": "1.0.2",
	"description": "Vercel AI SDK Provider for Free OpenAI API access with your ChatGPT account.",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --outDir dist --clean",
		"prepublishOnly": "bun run build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:live": "LIVE_CODEX_E2E=1 vitest run test/live.e2e.test.ts"
	},
	"dependencies": {
		"@ai-sdk/provider": "3.0.8",
		"@ai-sdk/provider-utils": "4.0.19"
	},
	"peerDependencies": {
		"@ai-sdk/openai": "^3.0.41",
		"ai": "^6.0.116"
	},
	"devDependencies": {
		"@ai-sdk/openai": "3.0.41",
		"@ai-sdk/provider": "3.0.8",
		"ai": "6.0.116",
		"@types/node": "20.17.24",
		"openai-oauth-core": "workspace:*",
		"typescript": "latest",
		"vitest": "latest",
		"zod": "^3.25.76"
	},
	"author": "EvanZhouDev",
	"license": "AGPL-3.0-only",
	"bugs": {
		"url": "https://github.com/EvanZhouDev/openai-oauth/issues"
	},
	"homepage": "https://github.com/EvanZhouDev/openai-oauth#readme"
}
